  "nodes": [
    {
      "id": "create_request_record",
      "kind": "tool",
      "inputs": {
        "input": "$state.input"
      },
      "outputs": {
        "request": "$result"
      },
      "config": {},
      "tool_ref": "workflow.create_request"
    },
    {
      "id": "generate_ai_brief",
      "kind": "llm",
      "inputs": {
        "input": "$state.input"
      },
      "outputs": {
        "brief": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты преобразуешь raw-заявку на телевизионную графику в структурированный AI-бриф. Возвращай только JSON.",
        "prompt_template": "Сырые данные заявки: {{input}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "channel": {
              "type": "string"
            },
            "program": {
              "type": "string"
            },
            "deadline": {
              "type": "string"
            },
            "urgency": {
              "type": "string"
            },
            "requested_type": {
              "type": "string"
            },
            "texts": {
              "type": "array"
            },
            "numbers": {
              "type": "array"
            },
            "sources": {
              "type": "array"
            },
            "references": {
              "type": "array"
            },
            "constraints": {
              "type": "array"
            }
          },
          "required": ["deadline", "urgency"]
        }
      },
      "tool_ref": null
    },
    {
      "id": "validate_brief",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief"
      },
      "outputs": {
        "validation": "$result"
      },
      "config": {
        "handler": "brief.validate"
      },
      "tool_ref": null
    },
    {
      "id": "request_clarification",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "validation": "$state.validation"
      },
      "outputs": {
        "clarification": "$result"
      },
      "config": {
        "message_template": "В заявке не хватает обязательных данных. Предоставьте недостающие поля, источники цифр, ограничения, формулировки и референсы."
      },
      "tool_ref": null
    },
    {
      "id": "merge_clarification",
      "kind": "function",
      "inputs": {
        "input": "$state.input",
        "clarification": "$state.clarification"
      },
      "outputs": {
        "input": "$result"
      },
      "config": {
        "handler": "brief.merge_clarification"
      },
      "tool_ref": null
    },
    {
      "id": "confirm_route_priority",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief",
        "request": "$state.request"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "handler": "routing.confirm_route_priority"
      },
      "tool_ref": null
    },
    {
      "id": "resolve_priority_conflict",
      "kind": "approval",
      "inputs": {
        "classification": "$state.classification",
        "request": "$state.request"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "message_template": "Обнаружен конфликт приоритетов. Подтвердите итоговый приоритет, срок и маршрут исполнения."
      },
      "tool_ref": null
    },
    {
      "id": "fetch_design_guidelines",
      "kind": "retrieval",
      "inputs": {
        "route": "$state.classification.route"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "source": "design_guidelines",
        "top_k": 5
      },
      "tool_ref": null
    },
    {
      "id": "prepare_draft_spec",
      "kind": "llm",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification",
        "guidelines": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты готовишь structured generation spec для AI draft по телевизионной графике. Возвращай только JSON.",
        "prompt_template": "Бриф: {{brief}}\nКлассификация: {{classification}}\nГайдлайны: {{guidelines}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "style": {
              "type": "string"
            },
            "template_family": {
              "type": "string"
            },
            "payload": {
              "type": "object"
            },
            "variants_count": {
              "type": "integer"
            },
            "quality_checks": {
              "type": "array"
            }
          },
          "required": ["payload"]
        }
      },
      "tool_ref": null
    },
    {
      "id": "assign_rt_task",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "classification": "$state.classification",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.assign_rt"
    },
    {
      "id": "assign_collage_task",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "classification": "$state.classification",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.assign_collage"
    },
    {
      "id": "assign_motion_task",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "classification": "$state.classification",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.assign_motion"
    },
    {
      "id": "generate_rt_draft",
      "kind": "tool",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification",
        "generation_spec": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "vizrt.create_rt_draft"
    },
    {
      "id": "generate_collage_draft",
      "kind": "tool",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification",
        "generation_spec": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "storage.create_collage_draft"
    },
    {
      "id": "generate_motion_draft",
      "kind": "tool",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification",
        "generation_spec": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "storage.create_motion_draft"
    },
    {
      "id": "rt_finalize",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "draft": "$state.result",
        "review_comments": "$state.review_comments"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "RT-дизайнер: доведите RT draft до финального ассета с учетом текущих комментариев."
      },
      "tool_ref": null
    },
    {
      "id": "collage_finalize",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "draft": "$state.result",
        "review_comments": "$state.review_comments"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "Коллажист: доработайте Collage draft до следующей версии с учетом текущих комментариев."
      },
      "tool_ref": null
    },
    {
      "id": "motion_finalize",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "draft": "$state.result",
        "review_comments": "$state.review_comments"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "Motion-дизайнер: подготовьте следующую стадию/версию Motion с учетом текущих комментариев."
      },
      "tool_ref": null
    },
    {
      "id": "editorial_review",
      "kind": "approval",
      "inputs": {
        "classification": "$state.classification",
        "asset": "$state.result"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Редакция: подтвердите asset. Верните status=approved, changes_requested или rejected, а также comments."
      },
      "tool_ref": null
    },
    {
      "id": "review_decision",
      "kind": "function",
      "inputs": {
        "approval": "$state.approval",
        "iteration_count": "$state.iteration_count"
      },
      "outputs": {
        "approval_status": "$result.approval_status",
        "review_comments": "$result.review_comments",
        "iteration_count": "$result.iteration_count",
        "error": "$result.error"
      },
      "config": {
        "handler": "review.process_outcome"
      },
      "tool_ref": null
    },
    {
      "id": "deploy_rt_to_air",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "asset": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "cosmedia.deploy_rt"
    },
    {
      "id": "publish_collage_final",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "asset": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "storage.publish_collage_final"
    },
    {
      "id": "publish_motion_final",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "asset": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "storage.publish_motion_final"
    },
    {
      "id": "handoff_to_editing",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "delivery": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "editing.handoff_assets"
    },
    {
      "id": "close_request",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "result": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.close_request"
    }
  ],

  "edges": [
    {
      "from": "START",
      "to": "create_request_record",
      "type": "direct"
    },
    {
      "from": "create_request_record",
      "to": "generate_ai_brief",
      "type": "direct"
    },
    {
      "from": "generate_ai_brief",
      "to": "validate_brief",
      "type": "direct"
    },
    {
      "from": "validate_brief",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              { "var": "validation.is_complete" },
              true
            ]
          },
          "to": "confirm_route_priority"
        },
        {
          "when": {
            "==": [
              { "var": "validation.is_complete" },
              false
            ]
          },
          "to": "request_clarification"
        }
      ]
    },
    {
      "from": "request_clarification",
      "to": "merge_clarification",
      "type": "direct"
    },
    {
      "from": "merge_clarification",
      "to": "generate_ai_brief",
      "type": "direct"
    },
    {
      "from": "confirm_route_priority",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              { "var": "classification.has_priority_conflict" },
              true
            ]
          },
          "to": "resolve_priority_conflict"
        },
        {
          "when": true,
          "to": "fetch_design_guidelines"
        }
      ]
    },
    {
      "from": "resolve_priority_conflict",
      "to": "fetch_design_guidelines",
      "type": "direct"
    },
    {
      "from": "fetch_design_guidelines",
      "to": "prepare_draft_spec",
      "type": "direct"
    },
    {
      "from": "prepare_draft_spec",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "rt"
            ]
          },
          "to": "assign_rt_task"
        },
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "collage"
            ]
          },
          "to": "assign_collage_task"
        },
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "motion"
            ]
          },
          "to": "assign_motion_task"
        },
        {
          "when": true,
          "to": "END"
        }
      ]
    },
    {
      "from": "assign_rt_task",
      "to": "generate_rt_draft",
      "type": "direct"
    },
    {
      "from": "assign_collage_task",
      "to": "generate_collage_draft",
      "type": "direct"
    },
    {
      "from": "assign_motion_task",
      "to": "generate_motion_draft",
      "type": "direct"
    },
    {
      "from": "generate_rt_draft",
      "to": "rt_finalize",
      "type": "direct"
    },
    {
      "from": "generate_collage_draft",
      "to": "collage_finalize",
      "type": "direct"
    },
    {
      "from": "generate_motion_draft",
      "to": "motion_finalize",
      "type": "direct"
    },
    {
      "from": "rt_finalize",
      "to": "editorial_review",
      "type": "direct"
    },
    {
      "from": "collage_finalize",
      "to": "editorial_review",
      "type": "direct"
    },
    {
      "from": "motion_finalize",
      "to": "editorial_review",
      "type": "direct"
    },
    {
      "from": "editorial_review",
      "to": "review_decision",
      "type": "direct"
    },
    {
      "from": "review_decision",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              { "var": "approval_status" },
              "approved"
            ]
          },
          "to": "deploy_rt_or_publish"
        },
        {
          "when": {
            "==": [
              { "var": "approval_status" },
              "changes_requested"
            ]
          },
          "to": "rework_router"
        },
        {
          "when": {
            "==": [
              { "var": "approval_status" },
              "rejected"
            ]
          },
          "to": "END"
        },
        {
          "when": {
            "==": [
              { "var": "approval_status" },
              "max_iterations_reached"
            ]
          },
          "to": "END"
        }
      ]
    },
    {
      "from": "deploy_rt_or_publish",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "rt"
            ]
          },
          "to": "deploy_rt_to_air"
        },
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "collage"
            ]
          },
          "to": "publish_collage_final"
        },
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "motion"
            ]
          },
          "to": "publish_motion_final"
        }
      ]
    },
    {
      "from": "rework_router",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "rt"
            ]
          },
          "to": "rt_finalize"
        },
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "collage"
            ]
          },
          "to": "collage_finalize"
        },
        {
          "when": {
            "==": [
              { "var": "classification.route" },
              "motion"
            ]
          },
          "to": "motion_finalize"
        }
      ]
    },
    {
      "from": "deploy_rt_to_air",
      "to": "close_request",
      "type": "direct"
    },
    {
      "from": "publish_collage_final",
      "to": "handoff_to_editing",
      "type": "direct"
    },
    {
      "from": "publish_motion_final",
      "to": "handoff_to_editing",
      "type": "direct"
    },
    {
      "from": "handoff_to_editing",
      "to": "close_request",
      "type": "direct"
    },
    {
      "from": "close_request",
      "to": "END",
      "type": "direct"
    }
  ],

  "execution": {
    "requires_checkpointer": true
  }
}
