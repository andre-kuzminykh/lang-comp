{
  "graph_id": "tv_graphics_production",

  "state_schema": {
    "input": "object",
    "brief": "object",
    "brief_validation": "object",
    "classification": "object",
    "retrieval_context": "object",
    "clarification": "object",
    "approval": "object",
    "approval_status": "string",
    "review_comments": "array",
    "iteration_count": "integer",
    "result": "object",
    "log": "array",
    "error": "string"
  },

  "tools": [
    {
      "id": "workflow.create_request",
      "kind": "unresolved",
      "description": "Создать заявку в едином реестре, запустить SLA-таймер и вернуть идентификатор заявки.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "workflow.send_clarification",
      "kind": "unresolved",
      "description": "Отправить редакции уточняющие вопросы по заявке через workflow/портал/бот.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "vizrt.publish_draft",
      "kind": "unresolved",
      "description": "Передать RT draft в VizRT и вернуть ссылку/идентификатор ассета.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "drop.publish_collage_draft",
      "kind": "unresolved",
      "description": "Сохранить draft Collage на сервере/Drop и вернуть путь/метаданные версии.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "drop.publish_motion_draft",
      "kind": "unresolved",
      "description": "Сохранить draft Motion на сервере/Drop и вернуть путь/метаданные версии.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "cosmedia.deploy_rt",
      "kind": "unresolved",
      "description": "Разместить утвержденный RT-ассет в эфирной системе Cosmedia.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "drop.publish_final_collage",
      "kind": "unresolved",
      "description": "Опубликовать финальный Collage на сервере/Drop и вернуть стандартную ссылку.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "drop.publish_final_motion",
      "kind": "unresolved",
      "description": "Опубликовать финальный Motion на сервере/Drop и вернуть стандартную ссылку.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "nle.send_links",
      "kind": "unresolved",
      "description": "Передать в монтаж ссылки на финальные Collage/Motion ассеты.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "workflow.close_request",
      "kind": "unresolved",
      "description": "Закрыть заявку по факту использования, отклонения или исчерпания лимита итераций.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    }
  ],

  "nodes": [
    {
      "id": "register_request",
      "kind": "tool",
      "inputs": {
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.create_request"
    },
    {
      "id": "build_ai_brief",
      "kind": "llm",
      "inputs": {
        "request": "$state.input"
      },
      "outputs": {
        "brief": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты формируешь структурированный AI-бриф для заявки на телевизионную графику. Верни только JSON с извлеченными полями, missing_fields, route_suggestion, urgency_suggestion, deadline_hint и confidence.",
        "prompt_template": "Заявка: {{request}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "normalized_request": {
              "type": "object"
            },
            "missing_fields": {
              "type": "array"
            },
            "route_suggestion": {
              "type": "string"
            },
            "urgency_suggestion": {
              "type": "string"
            },
            "deadline_hint": {
              "type": "string"
            },
            "confidence": {
              "type": "number"
            }
          },
          "required": [
            "normalized_request",
            "missing_fields",
            "route_suggestion",
            "urgency_suggestion",
            "deadline_hint",
            "confidence"
          ]
        }
      },
      "tool_ref": null
    },
    {
      "id": "validate_brief",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief",
        "request": "$state.input"
      },
      "outputs": {
        "brief_validation": "$result"
      },
      "config": {
        "handler": "brief.validate"
      },
      "tool_ref": null
    },
    {
      "id": "send_clarification_questions",
      "kind": "tool",
      "inputs": {
        "request": "$state.input",
        "brief_validation": "$state.brief_validation",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.send_clarification"
    },
    {
      "id": "await_clarification",
      "kind": "approval",
      "inputs": {
        "brief_validation": "$state.brief_validation"
      },
      "outputs": {
        "clarification": "$result"
      },
      "config": {
        "message_template": "Предоставьте недостающие данные по заявке: источники цифр, ограничения, формулировки, референсы, файлы или ссылки."
      },
      "tool_ref": null
    },
    {
      "id": "merge_clarification",
      "kind": "function",
      "inputs": {
        "request": "$state.input",
        "brief": "$state.brief",
        "clarification": "$state.clarification"
      },
      "outputs": {
        "input": "$result"
      },
      "config": {
        "handler": "brief.merge_clarification"
      },
      "tool_ref": null
    },
    {
      "id": "confirm_routing_and_priority",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief",
        "request": "$state.input"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "handler": "routing.confirm_priority"
      },
      "tool_ref": null
    },
    {
      "id": "resolve_priority_conflict",
      "kind": "approval",
      "inputs": {
        "classification": "$state.classification",
        "request": "$state.input"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Обнаружен конфликт приоритетов. Подтвердите приоритет, дедлайн и перераспределение ресурсов."
      },
      "tool_ref": null
    },
    {
      "id": "apply_priority_resolution",
      "kind": "function",
      "inputs": {
        "classification": "$state.classification",
        "approval": "$state.approval"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "handler": "routing.apply_resolution"
      },
      "tool_ref": null
    },
    {
      "id": "retrieve_design_context",
      "kind": "retrieval",
      "inputs": {
        "route": "$state.classification.route",
        "brief": "$state.brief"
      },
      "outputs": {
        "retrieval_context": "$result"
      },
      "config": {
        "source": "design_guidelines",
        "top_k": 5
      },
      "tool_ref": null
    },
    {
      "id": "generate_rt_draft",
      "kind": "llm",
      "inputs": {
        "brief": "$state.brief",
        "context": "$state.retrieval_context"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты готовишь structured JSON для RT draft: template, payload, preview_notes. Никаких side effects.",
        "prompt_template": "Бриф: {{brief}}\nКонтекст: {{context}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "template": {
              "type": "string"
            },
            "payload": {
              "type": "object"
            },
            "preview_notes": {
              "type": "array"
            }
          },
          "required": [
            "template",
            "payload",
            "preview_notes"
          ]
        }
      },
      "tool_ref": null
    },
    {
      "id": "publish_rt_draft_to_vizrt",
      "kind": "tool",
      "inputs": {
        "draft": "$state.result",
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "vizrt.publish_draft"
    },
    {
      "id": "rt_finalize",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "draft": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "RT-дизайнер: доведите RT draft до производственного качества и подтвердите готовность к редакционному review."
      },
      "tool_ref": null
    },
    {
      "id": "rt_editorial_review",
      "kind": "approval",
      "inputs": {
        "asset": "$state.result",
        "brief": "$state.brief"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Редакция: дайте решение по RT. Допустимые статусы: approved, changes_requested, rejected."
      },
      "tool_ref": null
    },
    {
      "id": "generate_collage_draft",
      "kind": "llm",
      "inputs": {
        "brief": "$state.brief",
        "context": "$state.retrieval_context"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты готовишь structured JSON для Collage draft: variants, asset_pack, preview_notes. Никаких side effects.",
        "prompt_template": "Бриф: {{brief}}\nКонтекст: {{context}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "variants": {
              "type": "array"
            },
            "asset_pack": {
              "type": "object"
            },
            "preview_notes": {
              "type": "array"
            }
          },
          "required": [
            "variants",
            "asset_pack",
            "preview_notes"
          ]
        }
      },
      "tool_ref": null
    },
    {
      "id": "publish_collage_draft_to_drop",
      "kind": "tool",
      "inputs": {
        "draft": "$state.result",
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_collage_draft"
    },
    {
      "id": "collage_finalize",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "draft": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "Коллажист: доработайте Collage draft и подтвердите готовность к редакционному review."
      },
      "tool_ref": null
    },
    {
      "id": "collage_editorial_review",
      "kind": "approval",
      "inputs": {
        "asset": "$state.result",
        "brief": "$state.brief"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Редакция: дайте решение по Collage. Допустимые статусы: approved, changes_requested, rejected."
      },
      "tool_ref": null
    },
    {
      "id": "generate_motion_draft",
      "kind": "llm",
      "inputs": {
        "brief": "$state.brief",
        "context": "$state.retrieval_context"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты готовишь structured JSON для Motion draft: styleframes, animatic_outline, preview_notes. Никаких side effects.",
        "prompt_template": "Бриф: {{brief}}\nКонтекст: {{context}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "styleframes": {
              "type": "array"
            },
            "animatic_outline": {
              "type": "object"
            },
            "preview_notes": {
              "type": "array"
            }
          },
          "required": [
            "styleframes",
            "animatic_outline",
            "preview_notes"
          ]
        }
      },
      "tool_ref": null
    },
    {
      "id": "publish_motion_draft_to_drop",
      "kind": "tool",
      "inputs": {
        "draft": "$state.result",
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_motion_draft"
    },
    {
      "id": "motion_finalize",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "draft": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "Motion-дизайнер: выполните продакшн/рендер на основе Motion draft и подтвердите готовность к редакционному review."
      },
      "tool_ref": null
    },
    {
      "id": "motion_editorial_review",
      "kind": "approval",
      "inputs": {
        "asset": "$state.result",
        "brief": "$state.brief"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Редакция: дайте решение по Motion. Допустимые статусы: approved, changes_requested, rejected."
      },
      "tool_ref": null
    },
    {
      "id": "capture_review_outcome",
      "kind": "function",
      "inputs": {
        "approval": "$state.approval",
        "iteration_count": "$state.iteration_count"
      },
      "outputs": {
        "approval_status": "$result.approval_status",
        "review_comments": "$result.review_comments",
        "iteration_count": "$result.iteration_count"
      },
      "config": {
        "handler": "review.capture_outcome"
      },
      "tool_ref": null
    },
    {
      "id": "rt_rework",
      "kind": "approval",
      "inputs": {
        "comments": "$state.review_comments",
        "asset": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "RT-дизайнер: внесите правки по комментариям редакции и верните обновленный RT-ассет."
      },
      "tool_ref": null
    },
    {
      "id": "collage_rework",
      "kind": "approval",
      "inputs": {
        "comments": "$state.review_comments",
        "asset": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "Коллажист: внесите правки по комментариям редакции и верните обновленный Collage."
      },
      "tool_ref": null
    },
    {
      "id": "motion_rework",
      "kind": "approval",
      "inputs": {
        "comments": "$state.review_comments",
        "asset": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "message_template": "Motion-дизайнер: внесите правки по комментариям редакции и верните обновленный Motion."
      },
      "tool_ref": null
    },
    {
      "id": "deploy_rt_to_cosmedia",
      "kind": "tool",
      "inputs": {
        "asset": "$state.result",
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "cosmedia.deploy_rt"
    },
    {
      "id": "publish_final_collage",
      "kind": "tool",
      "inputs": {
        "asset": "$state.result",
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_final_collage"
    },
    {
      "id": "publish_final_motion",
      "kind": "tool",
      "inputs": {
        "asset": "$state.result",
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_final_motion"
    },
    {
      "id": "send_assets_to_nle",
      "kind": "tool",
      "inputs": {
        "asset": "$state.result",
        "request": "$state.input",
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "nle.send_links"
    },
    {
      "id": "close_request",
      "kind": "tool",
      "inputs": {
        "request": "$state.input",
        "classification": "$state.classification",
        "result": "$state.result",
        "approval_status": "$state.approval_status",
        "iteration_count": "$state.iteration_count",
        "error": "$state.error"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.close_request"
    }
  ],

  "edges": [
    {
      "from": "START",
      "to": "register_request",
      "type": "direct"
    },
    {
      "from": "register_request",
      "to": "build_ai_brief",
      "type": "direct"
    },
    {
      "from": "build_ai_brief",
      "to": "validate_brief",
      "type": "direct"
    },
    {
      "from": "validate_brief",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "brief_validation.status"
              },
              "complete"
            ]
          },
          "to": "confirm_routing_and_priority"
        },
        {
          "when": {
            "==": [
              {
                "var": "brief_validation.status"
              },
              "missing_data"
            ]
          },
          "to": "send_clarification_questions"
        },
        {
          "when": true,
          "to": "close_request"
        }
      ]
    },
    {
      "from": "send_clarification_questions",
      "to": "await_clarification",
      "type": "direct"
    },
    {
      "from": "await_clarification",
      "to": "merge_clarification",
      "type": "direct"
    },
    {
      "from": "merge_clarification",
      "to": "build_ai_brief",
      "type": "direct"
    },
    {
      "from": "confirm_routing_and_priority",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "classification.priority_conflict"
              },
              true
            ]
          },
          "to": "resolve_priority_conflict"
        },
        {
          "when": true,
          "to": "retrieve_design_context"
        }
      ]
    },
    {
      "from": "resolve_priority_conflict",
      "to": "apply_priority_resolution",
      "type": "direct"
    },
    {
      "from": "apply_priority_resolution",
      "to": "retrieve_design_context",
      "type": "direct"
    },
    {
      "from": "retrieve_design_context",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "rt"
            ]
          },
          "to": "generate_rt_draft"
        },
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "collage"
            ]
          },
          "to": "generate_collage_draft"
        },
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "motion"
            ]
          },
          "to": "generate_motion_draft"
        },
        {
          "when": true,
          "to": "close_request"
        }
      ]
    },
    {
      "from": "generate_rt_draft",
      "to": "publish_rt_draft_to_vizrt",
      "type": "direct"
    },
    {
      "from": "publish_rt_draft_to_vizrt",
      "to": "rt_finalize",
      "type": "direct"
    },
    {
      "from": "rt_finalize",
      "to": "rt_editorial_review",
      "type": "direct"
    },
    {
      "from": "generate_collage_draft",
      "to": "publish_collage_draft_to_drop",
      "type": "direct"
    },
    {
      "from": "publish_collage_draft_to_drop",
      "to": "collage_finalize",
      "type": "direct"
    },
    {
      "from": "collage_finalize",
      "to": "collage_editorial_review",
      "type": "direct"
    },
    {
      "from": "generate_motion_draft",
      "to": "publish_motion_draft_to_drop",
      "type": "direct"
    },
    {
      "from": "publish_motion_draft_to_drop",
      "to": "motion_finalize",
      "type": "direct"
    },
    {
      "from": "motion_finalize",
      "to": "motion_editorial_review",
      "type": "direct"
    },
    {
      "from": "rt_editorial_review",
      "to": "capture_review_outcome",
      "type": "direct"
    },
    {
      "from": "collage_editorial_review",
