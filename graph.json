  "nodes": [
    {
      "id": "create_request_record",
      "kind": "tool",
      "inputs": {
        "input": "$state.input"
      },
      "outputs": {
        "request": "$result"
      },
      "config": {},
      "tool_ref": "workflow.create_request"
    },
    {
      "id": "generate_ai_brief",
      "kind": "llm",
      "inputs": {
        "input": "$state.input"
      },
      "outputs": {
        "brief": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты формируешь структурированный AI-бриф для производства телевизионной графики. Верни только JSON с нормализованными полями заявки и рекомендациями.",
        "prompt_template": "Сырые данные заявки: {{input}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "request_text": {
              "type": "string"
            },
            "channel": {
              "type": ["string", "null"]
            },
            "program": {
              "type": ["string", "null"]
            },
            "deadline": {
              "type": ["string", "null"]
            },
            "urgency": {
              "type": ["string", "null"]
            },
            "requested_type": {
              "type": ["string", "null"]
            },
            "texts": {
              "type": "array"
            },
            "numbers": {
              "type": "array"
            },
            "sources": {
              "type": "array"
            },
            "references": {
              "type": "array"
            },
            "constraints": {
              "type": "array"
            },
            "recommended_route": {
              "type": ["string", "null"]
            },
            "recommended_urgency": {
              "type": ["string", "null"]
            },
            "confidence": {
              "type": "number"
            }
          },
          "required": [
            "request_text",
            "channel",
            "program",
            "deadline",
            "urgency",
            "requested_type",
            "texts",
            "numbers",
            "sources",
            "references",
            "constraints",
            "recommended_route",
            "recommended_urgency",
            "confidence"
          ]
        }
      },
      "tool_ref": null
    },
    {
      "id": "validate_brief",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief"
      },
      "outputs": {
        "brief_validation": "$result"
      },
      "config": {
        "handler": "workflow.validate_brief"
      },
      "tool_ref": null
    },
    {
      "id": "send_clarification_request",
      "kind": "tool",
      "inputs": {
        "request": "$state.request",
        "brief": "$state.brief",
        "missing_fields": "$state.brief_validation.missing_fields",
        "blocking_reason": "$state.brief_validation.blocking_reason"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.send_clarification"
    },
    {
      "id": "wait_for_clarification",
      "kind": "approval",
      "inputs": {
        "request": "$state.request",
        "brief": "$state.brief",
        "brief_validation": "$state.brief_validation"
      },
      "outputs": {
        "input": "$result"
      },
      "config": {
        "message_template": "Предоставьте недостающие данные по заявке: {{brief_validation.missing_fields}}. Без этого заявка не может перейти в производство."
      },
      "tool_ref": null
    },
    {
      "id": "mark_invalid_request",
      "kind": "function",
      "inputs": {
        "request": "$state.request",
        "brief_validation": "$state.brief_validation"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "handler": "workflow.mark_invalid_request"
      },
      "tool_ref": null
    },
    {
      "id": "supervisor_triage",
      "kind": "approval",
      "inputs": {
        "request": "$state.request",
        "brief": "$state.brief"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "message_template": "Подтвердите route, urgency и deadline. Route должен быть одним из: rt, collage, motion."
      },
      "tool_ref": null
    },
    {
      "id": "check_priority_conflict",
      "kind": "function",
      "inputs": {
        "request": "$state.request",
        "classification": "$state.classification"
      },
      "outputs": {
        "priority_check": "$result"
      },
      "config": {
        "handler": "workflow.check_priority_conflict"
      },
      "tool_ref": null
    },
    {
      "id": "hd_priority_resolution",
