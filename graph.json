{
  "graph_id": "tv_graphics_production",

  "state_schema": {
    "input": "object",
    "brief": "object",
    "classification": "object",
    "result": "object",
    "approval": "object",
    "approval_status": "string",
    "review_comments": "array",
    "iteration_count": "integer",
    "log": "array",
    "error": "object"
  },

  "tools": [
    {
      "id": "workflow.register_request",
      "kind": "unresolved",
      "description": "Create request in unified workflow registry and start SLA tracking.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "workflow.assign_executor",
      "kind": "unresolved",
      "description": "Assign request to a specific executor or queue based on route and workload.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "vizrt.create_draft",
      "kind": "unresolved",
      "description": "Create RT draft asset in VizRT using template and payload.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "drop.publish_draft",
      "kind": "unresolved",
      "description": "Publish collage or motion draft package, previews, and versions to Drop/server.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "vizrt.publish_final",
      "kind": "unresolved",
      "description": "Publish finalized RT asset to VizRT or linked RT asset store.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "drop.publish_final",
      "kind": "unresolved",
      "description": "Publish finalized collage or motion files to server/Drop with version metadata.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "cosmedia.deploy_asset",
      "kind": "unresolved",
      "description": "Deploy approved RT asset to on-air system.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "nle.send_links",
      "kind": "unresolved",
      "description": "Send final asset links and metadata to editing/NLE.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    },
    {
      "id": "workflow.close_request",
      "kind": "unresolved",
      "description": "Close request and persist completion facts and delivery outcome.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "transport": {
        "server": null,
        "tool_name": null
      }
    }
  ],

  "nodes": [
    {
      "id": "register_request",
      "kind": "tool",
      "inputs": {
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.register_request"
    },
    {
      "id": "build_ai_brief",
      "kind": "llm",
      "inputs": {
        "request": "$state.input"
      },
      "outputs": {
        "brief": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты преобразуешь сырую заявку на телевизионную графику в структурированный AI-бриф. Верни только JSON. Извлеки обязательные поля, недостающие поля, рекомендованный тип задачи, срочность и confidence.",
        "prompt_template": "Raw request: {{request}}",
        "output_schema": {
          "type": "object",
          "properties": {
            "normalized_brief": {
              "type": "object"
            },
            "missing_fields": {
              "type": "array"
            },
            "recommended_route": {
              "type": "string"
            },
            "urgency": {
              "type": "string"
            },
            "confidence": {
              "type": "number"
            }
          },
          "required": [
            "normalized_brief",
            "missing_fields",
            "recommended_route",
            "urgency",
            "confidence"
          ]
        }
      },
      "tool_ref": null
    },
    {
      "id": "validate_brief",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "handler": "brief.validate"
      },
      "tool_ref": null
    },
    {
      "id": "request_clarification",
      "kind": "approval",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "В заявке не хватает обязательных данных. Предоставьте недостающие поля, источники, ограничения, формулировки, запреты, референсы или файлы."
      },
      "tool_ref": null
    },
    {
      "id": "confirm_routing",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief",
        "approval": "$state.approval"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "handler": "routing.confirm_type_and_urgency"
      },
      "tool_ref": null
    },
    {
      "id": "check_priority_conflict",
      "kind": "function",
      "inputs": {
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "handler": "priority.check_conflict"
      },
      "tool_ref": null
    },
    {
      "id": "resolve_priority_conflict",
      "kind": "approval",
      "inputs": {
        "classification": "$state.classification",
        "result": "$state.result"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Обнаружен конфликт приоритетов или ресурсов. Подтвердите приоритет и перераспределение ресурсов."
      },
      "tool_ref": null
    },
    {
      "id": "assign_rt",
      "kind": "tool",
      "inputs": {
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.assign_executor"
    },
    {
      "id": "assign_collage",
      "kind": "tool",
      "inputs": {
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.assign_executor"
    },
    {
      "id": "assign_motion",
      "kind": "tool",
      "inputs": {
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.assign_executor"
    },
    {
      "id": "generate_rt_draft",
      "kind": "tool",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "vizrt.create_draft"
    },
    {
      "id": "generate_collage_draft",
      "kind": "tool",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_draft"
    },
    {
      "id": "generate_motion_draft",
      "kind": "tool",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_draft"
    },
    {
      "id": "finalize_rt",
      "kind": "tool",
      "inputs": {
        "result": "$state.result",
        "review_comments": "$state.review_comments"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "vizrt.publish_final"
    },
    {
      "id": "finalize_collage",
      "kind": "tool",
      "inputs": {
        "result": "$state.result",
        "review_comments": "$state.review_comments"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_final"
    },
    {
      "id": "finalize_motion",
      "kind": "tool",
      "inputs": {
        "result": "$state.result",
        "review_comments": "$state.review_comments"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "drop.publish_final"
    },
    {
      "id": "editorial_review",
      "kind": "approval",
      "inputs": {
        "classification": "$state.classification",
        "result": "$state.result",
        "iteration_count": "$state.iteration_count"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Проверьте результат и верните один из статусов: approved, changes_requested, rejected. Если нужны правки, укажите комментарии."
      },
      "tool_ref": null
    },
    {
      "id": "apply_rework",
      "kind": "function",
      "inputs": {
        "approval": "$state.approval",
        "iteration_count": "$state.iteration_count",
        "classification": "$state.classification"
      },
      "outputs": {
        "review_comments": "$result"
      },
      "config": {
        "handler": "review.prepare_rework"
      },
      "tool_ref": null
    },
    {
      "id": "route_delivery",
      "kind": "function",
      "inputs": {
        "classification": "$state.classification",
        "approval": "$state.approval",
        "result": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "handler": "delivery.route_final_channel"
      },
      "tool_ref": null
    },
    {
      "id": "deploy_rt_on_air",
      "kind": "tool",
      "inputs": {
        "result": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "cosmedia.deploy_asset"
    },
    {
      "id": "handoff_to_editing",
      "kind": "tool",
      "inputs": {
        "result": "$state.result"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "nle.send_links"
    },
    {
      "id": "close_request",
      "kind": "tool",
      "inputs": {
        "classification": "$state.classification",
        "result": "$state.result",
        "approval": "$state.approval"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.close_request"
    }
  ],

  "edges": [
    {
      "from": "START",
      "to": "register_request",
      "type": "direct"
    },
    {
      "from": "register_request",
      "to": "build_ai_brief",
      "type": "direct"
    },
    {
      "from": "build_ai_brief",
      "to": "validate_brief",
      "type": "direct"
    },
    {
      "from": "validate_brief",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "classification.is_complete"
              },
              true
            ]
          },
          "to": "confirm_routing"
        },
        {
          "when": true,
          "to": "request_clarification"
        }
      ]
    },
    {
      "from": "request_clarification",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "approval.status"
              },
              "provided"
            ]
          },
          "to": "build_ai_brief"
        },
        {
          "when": {
            "==": [
              {
                "var": "approval.status"
              },
              "rejected"
            ]
          },
          "to": "END"
        },
        {
          "when": true,
          "to": "END"
        }
      ]
    },
    {
      "from": "confirm_routing",
      "to": "check_priority_conflict",
      "type": "direct"
    },
    {
      "from": "check_priority_conflict",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "result.conflict"
              },
              true
            ]
          },
          "to": "resolve_priority_conflict"
        },
        {
          "when": true,
          "to": "assign_rt"
        }
      ]
    },
    {
      "from": "resolve_priority_conflict",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "approval.status"
              },
              "approved"
            ]
          },
          "to": "assign_rt"
        },
        {
          "when": {
            "==": [
              {
                "var": "approval.status"
              },
              "rejected"
            ]
          },
          "to": "END"
        },
        {
          "when": true,
          "to": "END"
        }
      ]
    },
    {
      "from": "assign_rt",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "rt"
            ]
          },
          "to": "generate_rt_draft"
        },
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "collage"
            ]
          },
          "to": "assign_collage"
        },
        {
          "when": true,
          "to": "assign_motion"
        }
      ]
    },
    {
      "from": "assign_collage",
      "to": "generate_collage_draft",
      "type": "direct"
    },
    {
      "from": "assign_motion",
      "to": "generate_motion_draft",
      "type": "direct"
    },
    {
      "from": "generate_rt_draft",
      "to": "finalize_rt",
      "type": "direct"
    },
    {
      "from": "generate_collage_draft",
      "to": "finalize_collage",
      "type": "direct"
    },
    {
      "from": "generate_motion_draft",
      "to": "finalize_motion",
      "type": "direct"
    },
    {
      "from": "finalize_rt",
      "to": "editorial_review",
      "type": "direct"
    },
    {
      "from": "finalize_collage",
      "to": "editorial_review",
      "type": "direct"
    },
    {
      "from": "finalize_motion",
      "to": "editorial_review",
      "type": "direct"
    },
    {
      "from": "editorial_review",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "approval.status"
              },
              "approved"
            ]
          },
          "to": "route_delivery"
        },
        {
          "when": {
            "==": [
              {
                "var": "approval.status"
              },
              "changes_requested"
            ]
          },
          "to": "apply_rework"
        },
        {
          "when": {
            "==": [
              {
                "var": "approval.status"
              },
              "rejected"
            ]
          },
          "to": "END"
        },
        {
          "when": true,
          "to": "END"
        }
      ]
    },
    {
      "from": "apply_rework",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "rt"
            ]
          },
          "to": "finalize_rt"
        },
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "collage"
            ]
          },
          "to": "finalize_collage"
        },
        {
          "when": {
            "==": [
              {
                "var": "classification.route"
              },
              "motion"
            ]
          },
          "to": "finalize_motion"
        },
        {
          "when": true,
          "to": "END"
        }
      ]
    },
    {
      "from": "route_delivery",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "result.delivery_channel"
              },
              "on_air"
            ]
          },
          "to": "deploy_rt_on_air"
        },
        {
          "when": {
            "==": [
              {
                "var": "result.delivery_channel"
              },
              "editing"
            ]
          },
          "to": "handoff_to_editing"
        },
        {
          "when": true,
          "to": "END"
        }
      ]
    },
    {
      "from": "deploy_rt_on_air",
      "to": "close_request",
      "type": "direct"
    },
    {
      "from": "handoff_to_editing",
      "to": "close_request",
      "type": "direct"
    },
    {
      "from": "close_request",
      "to": "END",
      "type": "direct"
    }
  ],

  "execution": {
    "requires_checkpointer": true
  }
}
