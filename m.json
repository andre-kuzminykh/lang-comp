  "nodes": [
    {
      "id": "register_request",
      "kind": "tool",
      "inputs": {
        "request": "$state.input"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "workflow.register_request"
    },
    {
      "id": "generate_ai_brief",
      "kind": "llm",
      "inputs": {
        "request": "$state.input",
        "clarification": "$state.clarification"
      },
      "outputs": {
        "brief": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты формируешь структурированный AI-бриф для производства телевизионной графики. Верни только JSON.",
        "prompt_template": "Собери нормализованный бриф из raw-заявки и возможных уточнений. Укажи тексты, числовые данные, источники, дедлайн, ограничения, канал, программу, референсы и предполагаемый тип исполнения.",
        "output_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "channel": {
              "type": "string"
            },
            "program": {
              "type": "string"
            },
            "deadline": {
              "type": ["string", "null"]
            },
            "urgency": {
              "type": "string"
            },
            "requested_type": {
              "type": ["string", "null"],
              "enum": ["rt", "collage", "motion", null]
            },
            "content_items": {
              "type": "array"
            },
            "numeric_sources": {
              "type": "array"
            },
            "constraints": {
              "type": "array"
            },
            "references": {
              "type": "array"
            }
          },
          "required": ["title", "urgency", "content_items", "numeric_sources", "constraints", "references"]
        }
      },
      "tool_ref": null
    },
    {
      "id": "validate_brief",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief"
      },
      "outputs": {
        "brief_validation": "$result"
      },
      "config": {
        "handler": "brief.validate"
      },
      "tool_ref": null
    },
    {
      "id": "request_clarification",
      "kind": "tool",
      "inputs": {
        "request_id": "$state.result.request_id",
        "questions": "$state.brief_validation.missing_fields"
      },
      "outputs": {
        "log": "$result"
      },
      "config": {},
      "tool_ref": "comms.send_clarification_request"
    },
    {
      "id": "wait_for_clarification",
      "kind": "approval",
      "inputs": {
        "brief_validation": "$state.brief_validation"
      },
      "outputs": {
        "clarification": "$result"
      },
      "config": {
        "message_template": "Нужны уточнения по заявке. Предоставьте недостающие данные, файлы или ссылки. Статус ответа: responded или cancelled."
      },
      "tool_ref": null
    },
    {
      "id": "merge_clarification",
      "kind": "function",
      "inputs": {
        "request": "$state.input",
        "clarification": "$state.clarification"
      },
      "outputs": {
        "input": "$result"
      },
      "config": {
        "handler": "brief.merge_clarification"
      },
      "tool_ref": null
    },
    {
      "id": "route_and_prioritize",
      "kind": "function",
      "inputs": {
        "brief": "$state.brief"
      },
      "outputs": {
        "classification": "$result"
      },
      "config": {
        "handler": "routing.route_and_prioritize"
      },
      "tool_ref": null
    },
    {
      "id": "resolve_priority_conflict",
      "kind": "approval",
      "inputs": {
        "classification": "$state.classification"
      },
      "outputs": {
        "approval": "$result"
      },
      "config": {
        "message_template": "Обнаружен конфликт приоритетов. Руководитель департамента должен утвердить приоритет и перераспределение ресурсов."
      },
      "tool_ref": null
    },
    {
      "id": "retrieve_design_context",
      "kind": "retrieval",
      "inputs": {
        "route": "$state.classification.route",
        "brief": "$state.brief"
      },
      "outputs": {
        "context_docs": "$result"
      },
      "config": {
        "source": "design_guidelines_kb",
        "top_k": 5
      },
      "tool_ref": null
    },
    {
      "id": "generate_draft_spec",
      "kind": "llm",
      "inputs": {
        "brief": "$state.brief",
        "classification": "$state.classification",
        "context_docs": "$state.context_docs"
      },
      "outputs": {
        "draft_spec": "$result"
      },
      "config": {
        "model": "gpt-4.1",
        "system_prompt": "Ты готовишь structured draft spec для AI-first производства телевизионной графики. Верни только JSON.",
        "prompt_template": "На основе брифа, route и retrieved guidelines подготовь draft spec для дальнейшего создания драфта в нужной системе.",
        "output_schema": {
          "type": "object",
          "properties": {
            "route": {
              "type": "string",
              "enum": ["rt", "collage", "motion"]
            },
            "style_direction": {
              "type": "string"
            },
            "template_hint": {
              "type": ["string", "null"]
            },
            "variants_count": {
              "type": "integer"
            },
            "payload": {
              "type": "object"
            }
          },
          "required": ["route", "style_direction", "variants_count", "payload"]
        }
      },
      "tool_ref": null
    },
    {
      "id": "create_rt_draft",
      "kind": "tool",
      "inputs": {
        "draft_spec": "$state.draft_spec"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "rt.create_draft_vizrt"
    },
    {
      "id": "create_collage_draft",
      "kind": "tool",
      "inputs": {
        "draft_spec": "$state.draft_spec"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "collage.create_draft_drop"
    },
    {
      "id": "create_motion_draft",
      "kind": "tool",
      "inputs": {
        "draft_spec": "$state.draft_spec"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "motion.create_draft_drop"
    },
    {
      "id": "finalize_rt_asset",
      "kind": "tool",
      "inputs": {
        "draft_asset": "$state.result",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "rt.finalize_asset_vizrt"
    },
    {
      "id": "finalize_collage_asset",
      "kind": "tool",
      "inputs": {
        "draft_asset": "$state.result",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "collage.finalize_asset_drop"
    },
    {
      "id": "finalize_motion_asset",
      "kind": "tool",
      "inputs": {
        "draft_asset": "$state.result",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "motion.finalize_asset_drop"
    },
    {
      "id": "editorial_review",
      "kind": "approval",
      "inputs": {
        "route": "$state.classification.route",
        "asset": "$state.result"
      },
      "outputs": {
        "approval": "$result",
        "approval_status": "$result.status",
        "review_comments": "$result.comments"
      },
      "config": {
        "message_template": "Проверьте текущий ассет и примите решение: approved, changes_requested или rejected. Комментарии обязательны при changes_requested и rejected."
      },
      "tool_ref": null
    },
    {
      "id": "update_iteration",
      "kind": "function",
      "inputs": {
        "iteration_count": "$state.iteration_count",
        "approval_status": "$state.approval_status",
        "review_comments": "$state.review_comments"
      },
      "outputs": {
        "iteration_count": "$result.iteration_count",
        "rework_control": "$result"
      },
      "config": {
        "handler": "review.update_iteration"
      },
      "tool_ref": null
    },
    {
      "id": "rework_rt_asset",
      "kind": "tool",
      "inputs": {
        "draft_asset": "$state.result",
        "comments": "$state.review_comments",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "rt.finalize_asset_vizrt"
    },
    {
      "id": "rework_collage_asset",
      "kind": "tool",
      "inputs": {
        "draft_asset": "$state.result",
        "comments": "$state.review_comments",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "collage.finalize_asset_drop"
    },
    {
      "id": "rework_motion_asset",
      "kind": "tool",
      "inputs": {
        "draft_asset": "$state.result",
        "comments": "$state.review_comments",
        "brief": "$state.brief"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {},
      "tool_ref": "motion.finalize_asset_drop"
    },
    {
      "id": "deploy_rt_asset",
      "kind": "tool",
      "inputs": {
        "asset": "$state.result"
      },
      "outputs": {
        "delivery": "$result"
      },
      "config": {},
      "tool_ref": "rt.deploy_cosmedia"
    },
    {
      "id": "publish_collage_final",
      "kind": "tool",
      "inputs": {
        "asset": "$state.result"
      },
      "outputs": {
        "delivery": "$result"
      },
      "config": {},
      "tool_ref": "collage.publish_final_drop"
    },
    {
      "id": "publish_motion_final",
      "kind": "tool",
      "inputs": {
        "asset": "$state.result"
      },
      "outputs": {
        "delivery": "$result"
      },
      "config": {},
      "tool_ref": "motion.publish_final_drop"
    },
    {
      "id": "handoff_to_nle",
      "kind": "tool",
      "inputs": {
        "delivery_ref": "$state.delivery.delivery_ref",
        "route": "$state.classification.route"
      },
      "outputs": {
        "delivery": "$result"
      },
      "config": {},
      "tool_ref": "delivery.send_links_to_nle"
    },
    {
      "id": "close_request",
      "kind": "function",
      "inputs": {
        "classification": "$state.classification",
        "brief_validation": "$state.brief_validation",
        "clarification": "$state.clarification",
        "approval_status": "$state.approval_status",
        "delivery": "$state.delivery",
        "rework_control": "$state.rework_control",
        "result": "$state.result",
        "error": "$state.error"
      },
      "outputs": {
        "result": "$result"
      },
      "config": {
        "handler": "workflow.close_request"
      },
      "tool_ref": null
    }
  ],

  "edges": [
    {
      "from": "START",
      "to": "register_request",
      "type": "direct"
    },
    {
      "from": "register_request",
      "to": "generate_ai_brief",
      "type": "direct"
    },
    {
      "from": "generate_ai_brief",
      "to": "validate_brief",
      "type": "direct"
    },
    {
      "from": "validate_brief",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "brief_validation.status"
              },
              "complete"
            ]
          },
          "to": "route_and_prioritize"
        },
        {
          "when": {
            "==": [
              {
                "var": "brief_validation.status"
              },
              "missing_data"
            ]
          },
          "to": "request_clarification"
        },
        {
          "when": true,
          "to": "close_request"
        }
      ]
    },
    {
      "from": "request_clarification",
      "to": "wait_for_clarification",
      "type": "direct"
    },
    {
      "from": "wait_for_clarification",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "clarification.status"
              },
              "responded"
            ]
          },
          "to": "merge_clarification"
        },
        {
          "when": true,
          "to": "close_request"
        }
      ]
    },
    {
      "from": "merge_clarification",
      "to": "generate_ai_brief",
      "type": "direct"
    },
    {
      "from": "route_and_prioritize",
      "type": "conditional",
      "conditions": [
        {
          "when": {
            "==": [
              {
                "var": "classification.priority_conflict"
              },
              true
            ]
          },
          "to": "resolve_priority_conflict"
        },
        {
          "when": true,
